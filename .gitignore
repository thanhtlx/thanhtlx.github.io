*.swo

# --- Node/Frontend (Nếu bạn dùng Tailwind, Webpack, hoặc Static Site Generators) ---
node_modules/
dist/
build/
.cache/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python/Data (Dành cho các script xử lý dữ liệu hoặc AutoML) ---
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/
.env
.pytest_cache/
.ipynb_checkpoints/

# --- Static Site Generators ---
# Nếu dùng Jekyll
_site/
.jekyll-cache/
.jekyll-metadata

# Nếu dùng Hugo
resources/_gen/
public/

# --- Logs & Temporary Files ---
*.log
tmp/
temp/